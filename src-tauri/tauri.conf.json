{
  "productName": "AnomTracker",
  "version": "0.1.2",
  "identifier": "com.anomtracker.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "EVE AnomTracker",
        "width": 360,
        "height": 720,
        "resizable": false,
        "fullscreen": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "default",
          "description": "Default capability",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "sql:default",
            "sql:allow-load",
            "sql:allow-execute",
            "sql:allow-select"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
