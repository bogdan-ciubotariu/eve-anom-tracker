{
  "productName": "EVE AnomTracker",
  "version": "0.1.2",
  "identifier": "com.anomtracker.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "EVE AnomTracker",
        "width": 360,
        "height": 725,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "visible": false
      },
      {
        "label": "splashscreen",
        "url": "/splashscreen.html",
        "width": 450,
        "height": 450,
        "transparent": true,
        "decorations": false,
        "center": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "default",
          "description": "Default capability",
          "windows": ["main", "splashscreen"],
          "permissions": [
            "core:default",
            "window-state:default",
            "core:window:allow-minimize",
            "core:window:allow-close",
            "core:window:allow-show",
            "core:window:allow-start-dragging",
            "sql:default",
            "sql:allow-load",
            "sql:allow-execute",
            "sql:allow-select",
            "fs:default",
            "dialog:default",
            "fs:allow-write",
            "fs:allow-read",
            "fs:allow-copy-file",
            "fs:allow-mkdir"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
